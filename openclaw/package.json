{
  "name": "openclaw-dna",
  "version": "0.5.3",
  "type": "module",
  "description": "DNA governance system — OpenClaw plugin for agentic-dna",
  "license": "Apache-2.0",
  "homepage": "https://github.com/exisz/agentic-dna/tree/main/openclaw#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/exisz/agentic-dna",
    "directory": "openclaw"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "dna",
    "governance",
    "agent-framework"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "test": "echo 'no tests yet'"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.28"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  }
}
