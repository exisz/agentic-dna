#!/bin/sh
# DNA CLI — Agentic DNA unified command
# Routes subcommands to appropriate handlers

# Resolve symlinks to find real repo location
_self="$0"
while [ -L "$_self" ]; do
  _dir="$(cd "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  case "$_self" in /*) ;; *) _self="$_dir/$_self" ;; esac
done
DNA_CODE="$(cd "$(dirname "$_self")/.." && pwd)"

# tsx runtime (bundled as a dependency)
TSX="$DNA_CODE/node_modules/.bin/tsx"

# Data directory: ~/.dna > ~/.openclaw/.dna > ~/.agentic-dna
if [ -d "$HOME/.dna" ]; then
  DNA_DATA="$HOME/.dna"
elif [ -d "$HOME/.openclaw/.dna" ]; then
  DNA_DATA="$HOME/.openclaw/.dna"
else
  DNA_DATA="$HOME/.agentic-dna"
fi
export DNA_DATA

_placeholder() {
  echo "🚧 dna $1 — not yet implemented (coming soon)" >&2
  exit 1
}

subcmd="${1:-help}"
shift 2>/dev/null

case "$subcmd" in
  spec)
    exec "$TSX" "$DNA_CODE/scripts/spec-cli.ts" "$@"
    ;;
  philosophy)
    exec "$TSX" "$DNA_CODE/scripts/philosophy-cli.ts" "$@"
    ;;
  convention)
    exec "$TSX" "$DNA_CODE/scripts/convention-cli.ts" "$@"
    ;;
  protocol)
    exec "$TSX" "$DNA_CODE/scripts/protocol-cli.ts" "$@"
    ;;
  architecture)
    echo "⚠️  'dna architecture' renamed to 'dna protocol'. Update your scripts." >&2
    exec "$TSX" "$DNA_CODE/scripts/protocol-cli.ts" "$@"
    ;;
  workflow)
    echo "⚠️  'dna workflow' renamed to 'dna protocol'. Update your scripts." >&2
    exec "$TSX" "$DNA_CODE/scripts/protocol-cli.ts" "$@"
    ;;
  flow)
    exec "$TSX" "$DNA_CODE/scripts/flow-cli.ts" "$@"
    ;;
  tool)
    exec "$TSX" "$DNA_CODE/scripts/tool-cli.ts" "$@"
    ;;
  skill)
    exec "$TSX" "$DNA_CODE/scripts/skill-cli.ts" "$@"
    ;;
  hydrate)
    exec "$TSX" "$DNA_CODE/scripts/hydrate-cli.ts" "$@"
    ;;
  injection)
    exec "$TSX" "$DNA_CODE/scripts/injection-cli.ts" "$@"
    ;;
  init)
    DATA_DIR="${DNA_DATA:-$HOME/.agentic-dna}"
    mkdir -p "$DATA_DIR/philosophies" "$DATA_DIR/conventions" "$DATA_DIR/protocols" "$DATA_DIR/flows"
    echo "🧬 DNA initialized at $DATA_DIR"
    echo "Add philosophy entries to $DATA_DIR/philosophy/"
    echo "Add conventions to $DATA_DIR/conventions/"
    echo "Add protocols to $DATA_DIR/protocols/"
    ;;
  help|--help|-h)
    echo "🧬 Agentic DNA — Governing Knowledge System"
    echo ""
    echo "Usage: dna <subcommand> [args]"
    echo ""
    echo "Subcommands:"
    echo "  init          Initialize data directory"
    echo "  spec          GBTD spec operations"
    echo "  philosophy    Philosophy database"
    echo "  convention    Convention rules — global & local"
    echo "  protocol       Protocol paradigms — git/CI/deploy levels"
  echo "  flow           Flow procedures — global & local"
    echo "  tool          Toolbox: invoke registered CLIs"
    echo "  skill         Manual skill operations"
    echo "  cron          Cron operations: frequency up/down"
    echo "  hydrate       Pre-render {{dna}} directives in workspace files"
    echo "  injection     Prompt injection files"
    echo ""
    echo "Examples:"
    echo "  dna init"
    echo "  dna hydrate --all"
    echo "  dna flow --list"
    ;;
  *)
    # Fallback: try tool routing (e.g. dna cron → dna tool cron)
    "$TSX" "$DNA_CODE/scripts/tool-cli.ts" --run "$subcmd" "$@"
    _exit=$?
    if [ $_exit -eq 127 ]; then
      echo "Unknown subcommand: $subcmd" >&2
      echo "Run 'dna help' for usage." >&2
      exit 1
    fi
    exit $_exit
    ;;
esac
